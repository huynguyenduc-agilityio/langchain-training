# Version control
.git
.gitignore

# Dependencies (will be installed in container)
node_modules
**/node_modules

# Build outputs (will be built in container)
**/.next
**/dist
**/.turbo

# Dev environment
**/.env
**/.env.local
**/.env.development

# IDE / OS
.vscode
.idea
**/.DS_Store
**/Thumbs.db

# Logs
**/logs
**/*.log

# Test files
**/__tests__
**/*.test.ts
**/*.spec.ts

# LangGraph local files
apps/agent/.langgraph_api
apps/agent/knowledge-base
apps/agent/docs
